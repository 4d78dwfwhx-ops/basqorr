{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basqor.com/schemas/telemetry/v2",
  "title": "BasqorUserTelemetryPayload",
  "description": "هيكل بيانات تيليميتري المستخدم لتغذية محرك الذكاء الاصطناعي",
  "type": "object",
  "properties": {
    "session_token": {
      "type": "string",
      "format": "uuid",
      "description": "رمز الجلسة الفريد"
    },
    "user_vector_class": {
      "type": "string",
      "enum": ["CUSTOMER", "SALVAGE_MERCHANT", "LOGISTICS_CAPTAIN"],
      "description": "تصنيف فئة المستخدم"
    },
    "platform_version": {
      "type": "string",
      "default": "2.0.0"
    },
    "realtime_telemetry": {
      "type": "object",
      "properties": {
        "geolocation_coordinates": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2,
          "description": "[latitude, longitude]"
        },
        "target_vin_context": {
          "type": "string",
          "maxLength": 17,
          "minLength": 17,
          "description": "رقم الهيكل المستهدف"
        },
        "device_info": {
          "type": "object",
          "properties": {
            "platform": { "type": "string", "enum": ["ios", "android", "web"] },
            "screen_size": { "type": "string" },
            "network_type": { "type": "string", "enum": ["wifi", "4g", "5g"] }
          }
        },
        "action_matrix": {
          "type": "object",
          "properties": {
            "funnel_stage": {
              "type": "string",
              "enum": [
                "VIN_SCAN",
                "PRICE_COMPARE",
                "WHATSAPP_REDIRECT",
                "ORDER_PLACED",
                "PAYMENT_COMPLETED"
              ]
            },
            "dwell_time_milliseconds": { "type": "integer", "minimum": 0 },
            "scroll_depth_percentage": { "type": "integer", "minimum": 0, "maximum": 100 },
            "interaction_count": { "type": "integer", "minimum": 0 }
          },
          "required": ["funnel_stage", "dwell_time_milliseconds"]
        }
      },
      "required": ["geolocation_coordinates", "action_matrix"]
    },
    "server_metadata": {
      "type": "object",
      "properties": {
        "server_timestamp": { "type": "string", "format": "date-time" },
        "server_region": { "type": "string", "default": "sa-east-1" },
        "payload_hash": { "type": "string" },
        "processing_time_ms": { "type": "number" }
      }
    }
  },
  "required": ["session_token", "user_vector_class", "realtime_telemetry"]
}